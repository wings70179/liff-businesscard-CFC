extends ../layout/default

block beforehtml
  -
    title = '分享 LINE 數位版名片'
    description = '請開啟本連結並按一下「分享好友」來分享給好友或群組。'

//- disable gtag
block compoment-gtag

block script
  script(crossorigin="anonymous", src="https://static.line-scdn.net/liff/edge/2/sdk.js")
  script.
    (async () => {
      try {
        // 使用你的 liffidFull 初始化
        await liff.init({ liffId: '#{liffidFull}' })
        
        // 處理 liff.state 轉址問題（解決你看到的長串亂碼）
        const url = new URL(location)
        if (url.searchParams.get('liff.state')) {
          const state = url.searchParams.get('liff.state')
          // 重新導向到乾淨的網址
          url.search = state.replace(/^\/?share.html/, '')
          url.searchParams.delete('liff.state')
          location.replace(url.href)
          return
        }

        // 如果未登入，引導登入
        if (!liff.isLoggedIn()) {
          liff.login({ redirectUri: location.href })
          return
        }

        // 只要網址有參數 (例如 ?name=...)
        // 專案內建的分享邏輯就會在頁面載入後自動跳出分享好友清單
        console.log('LIFF ready');
        
      } catch (err) {
        console.error('LIFF init error:', err)
      }
    })()