extends ../../layout/forms.pug

block beforehtml
  -
    title = '長富營造名片'
    description = '長富營造名片'

block meta
  meta(property="og:image:height", content="640")
  meta(property="og:image:width", content="1280")
  meta(property="og:image", content="https://raw.githubusercontent.com/wings70179/eccard/refs/heads/main/FJJ56x3v.png")
  meta(property="og:url", content=baseurl+"forms/liff-businesscard-whitegiga.html")

block form
  .form-group.was-validated.my-2
    label LOGO 圖片的網址
    input.form-control.form-control-sm(type="url", required, v-model.trim="vcard.logo")
  .form-group.was-validated.my-2
    label 姓名
    input.form-control.form-control-sm(type="text", required, v-model="vcard.name")
  .form-group.was-validated.my-2
    label 職稱
    input.form-control.form-control-sm(type="text", required, v-model="vcard.title")
  .form-group.was-validated.my-2
    label 手機
    input.form-control.form-control-sm(type="tel", required, v-model="vcard.cellphone")
  .form-group.was-validated.my-2
    label 公司名稱
    input.form-control.form-control-sm(type="text", required, v-model="vcard.company")
  .form-group.was-validated.my-2
    label 地址
    input.form-control.form-control-sm(type="text", required, v-model="vcard.address")
  .form-group.was-validated.my-2
    label 統編
    input.form-control.form-control-sm(type="text", required, v-model="vcard.taxid")
  .form-group.was-validated.my-2
    label 電話
    input.form-control.form-control-sm(type="tel", required, v-model="vcard.tel")
  .form-group.was-validated.my-2
    label 傳真
    input.form-control.form-control-sm(type="text", v-model="vcard.fax")
  .form-group.was-validated.my-2
    label 信箱
    input.form-control.form-control-sm(type="email", required, v-model="vcard.email")

